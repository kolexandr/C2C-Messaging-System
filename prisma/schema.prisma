generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  listings  Listing[]
  createdAt DateTime  @default(now())
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  imageUrl    String?
  sellerId    String
  seller      User @relation(fields: [sellerId], references: [id])

  createdAt   DateTime @default(now())
}